generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model administrador {
  id     Int     @id @default(autoincrement())
  nome   String  @db.VarChar(255)
  email  String  @unique @db.VarChar(255)
  senha  String  @db.VarChar(255)
  cursos curso[] @relation("AdminCursos")
}

model aluno {
  id               Int                @id @default(autoincrement())
  idcurso          Int
  nome             String             @db.VarChar(255)
  email            String             @unique @db.VarChar(255)
  senha            String             @db.VarChar(255)
  curso            curso              @relation("CursoAlunos", fields: [idcurso], references: [id], onDelete: Cascade, onUpdate: NoAction)
  aluno_disciplina aluno_disciplina[] @relation("AlunoDisciplinas")
}

model aluno_disciplina {
  id           Int        @id @default(autoincrement())
  idaluno      Int
  iddisciplina Int
  aprovado     Boolean    @default(false)
  periodoplan  Int?
  aluno        aluno      @relation("AlunoDisciplinas", fields: [idaluno], references: [id], onDelete: Cascade, onUpdate: NoAction)
  disciplina   disciplina @relation("DisciplinaAlunos", fields: [iddisciplina], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model curso {
  id             Int           @id @default(autoincrement())
  idadm          Int
  iduniversidade Int
  nome           String        @db.VarChar(255)
  nperiodos      Int
  alunos         aluno[]       @relation("CursoAlunos")
  administrador  administrador @relation("AdminCursos", fields: [idadm], references: [id], onDelete: NoAction, onUpdate: NoAction)
  universidade   universidade  @relation("UniversidadeCursos", fields: [iduniversidade], references: [id], onDelete: Cascade, onUpdate: NoAction)
  disciplinas    disciplina[]  @relation("CursoDisciplinas")
}

/// Dependências de disciplinas
model dependencia {
  id              Int        @id @default(autoincrement())
  iddisciplinareq Int
  iddisciplinadep Int
  dep             disciplina @relation("DisciplinaDependentes", fields: [iddisciplinadep], references: [id], onDelete: Cascade, onUpdate: NoAction)
  req             disciplina @relation("DisciplinaRequisitos", fields: [iddisciplinareq], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model disciplina {
  id                                                       Int                @id @default(autoincrement())
  idcurso                                                  Int
  nome                                                     String             @db.VarChar(255)
  periodo                                                  Int
  credito                                                  Int
  dificuldade                                              Int?
  informacao                                               String?            @db.VarChar(255)
  reqcreditos                                              Int?
  reqperiodo                                               Int?
  aluno_disciplina                                         aluno_disciplina[] @relation("DisciplinaAlunos")
  requisitos                                               dependencia[]      @relation("DisciplinaDependentes")
  dependentes                                              dependencia[]      @relation("DisciplinaRequisitos")
  correquisitos                                            correquisito[]     @relation("DisciplinaCorrequisitos")
  curso                                                    curso              @relation("CursoDisciplinas", fields: [idcurso], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model universidade {
  id     Int     @id @default(autoincrement())
  nome   String  @db.VarChar(255)
  cursos curso[] @relation("UniversidadeCursos")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model correquisito {
  id                                                     Int        @id @default(autoincrement())
  iddisciplina                                           Int
  iddisciplinacorreq                                     Int
  correq       disciplina @relation("DisciplinaCorrequisitos", fields: [iddisciplina], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
